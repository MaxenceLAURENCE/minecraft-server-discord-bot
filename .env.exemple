# Nom du projet (commande bash pour trouver le nom du dossier 2 niveau au dessus du fichier .env)
# PROJECT_NAME EST CALCULER AUTOMATIQUEMENT PAR LE .sh DE Dﾃ窺ARRAGE !!! 

# Nom conteneur 
MINECRAFT_CONTAINER_NAME=minecraft-server-DEV
BOT_CONTAINER_NAME=discord-bot-DEV

# Port (pas les port officiel, pour ne pas perturber le serveur DEV) 
MINECRAFT_PORT=25566
SSH_PORT=2223

# Token bot discord 
DISCORD_TOKEN=

# Mot de passe ssh 
SSH_PASSWORD=

# Mﾃｩmoire du serveur minecraft 
MEMORY=1G

# Dosser des mod (1er dﾃｩmarrage uniquement) 
MODS_DIR=./mods

# IP locale / Nom de domaine en DEV (laisser vide pour dﾃｩtection auto)
MINECRAFT_HOST=




